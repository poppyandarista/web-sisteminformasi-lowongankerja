<!DOCTYPE html>
    <html>
    <head>
        <meta charset="UTF-8">
        <title>Export Data Lowongan</title>
        <style>
            @page {
                margin: 1cm;
                size: A4 landscape;
            }
            body { 
                font-family: Arial, sans-serif; 
                margin: 20px; 
                font-size: 12px;
            }
            h1 { 
                color: #333; 
                text-align: center; 
                margin-bottom: 20px;
                font-size: 18px;
            }
            .header-info {
                margin-bottom: 20px;
                font-size: 10px;
                color: #666;
            }
            table { 
                width: 100%; 
                border-collapse: collapse; 
                margin-top: 20px; 
            }
            th, td { 
                border: 1px solid #ddd; 
                padding: 6px; 
                text-align: left; 
                font-size: 10px;
            }
            th { 
                background-color: #f2f2f2; 
                font-weight: bold; 
            }
            tr:nth-child(even) { background-color: #f9f9f9; }
            .summary { 
                margin-top: 20px; 
                font-weight: bold; 
                text-align: center;
                font-size: 12px;
            }
            .no-break {
                page-break-inside: avoid;
            }
        </style>
    </head>
    <body>
        <h1>LAPORAN DATA LOWONGAN</h1>
