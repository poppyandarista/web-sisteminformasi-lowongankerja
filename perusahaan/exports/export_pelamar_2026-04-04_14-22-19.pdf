                width: 100%; 
                border-collapse: collapse; 
                margin-top: 20px; 
            }
            th, td { 
                border: 1px solid #ddd; 
                padding: 6px; 
                text-align: left; 
                font-size: 9px;
            }
            th { 
                background-color: #4f46e5; 
                color: white; 
                font-weight: bold; 
            }
            tr:nth-child(even) { background-color: #f9f9f9; }
            .summary { 
                margin-top: 20px; 
                font-weight: bold; 
                text-align: center;
                font-size: 12px;
            }
